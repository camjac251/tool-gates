{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!**/target",
      "!docs/book",
      // wasm-bindgen output, regenerated by `mise run build-wasm`.
      "!docs/src/wasm",
      // Agent config, left exactly as authored.
      "!.claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        // mdBook ships its own stylesheet; these overrides need !important to win
        // the cascade against it.
        "noImportantStyles": "off"
      },
      "correctness": {
        // Theme JS is deliberate no-build vanilla JS; block-scoped var/function
        // declarations are intentional for browser support without a bundler.
        "noInnerDeclarations": "off"
      },
      "style": {
        // The highlight theme orders selectors per color scheme on purpose;
        // descending specificity is by design here.
        "noDescendingSpecificity": "off",
        // String concatenation is kept as authored in the HTML-building helpers.
        "useTemplate": "off"
      },
      "suspicious": {
        // The IIFE loads as a plain <script>, not a module, so its "use strict"
        // directive is meaningful, not redundant.
        "noRedundantUseStrict": "off"
      }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double" } }
}
